---
const links = [
	{ href: '/', label: 'home' },
	{ href: '/blog/', label: 'blog' },
	{ href: '/blog/resources/', label: 'resources' },
	{ href: '/blog/knowledge/', label: 'knowledge' },
	{ href: '/blog/thoughts/', label: 'thoughts' },
	{ href: '/blog/friends/', label: 'friends' },
	{ href: '/blog/comments/', label: 'comments' },
	{ href: '/about/', label: 'about' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
	<div class="site-header-inner">
		<a href="/" class="pixel-title site-brand">YIXUAN</a>
		<nav class="site-nav" aria-label="Primary navigation">
			{links.map((link) => <a class:list={{ active: isActive(link.href) }} href={link.href}>[{link.label}]</a>)}
		</nav>
	</div>
</header>
