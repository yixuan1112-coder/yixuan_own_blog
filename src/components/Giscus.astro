---
import { GISCUS } from '../consts';

const isConfigured = Boolean(GISCUS.repoId && GISCUS.categoryId);
---

<section class="giscus-wrapper">
	<h2>评论</h2>
	{
		isConfigured ? (
			<script
				is:inline
				src="https://giscus.app/client.js"
				data-repo={GISCUS.repo}
				data-repo-id={GISCUS.repoId}
				data-category={GISCUS.category}
				data-category-id={GISCUS.categoryId}
				data-mapping={GISCUS.mapping}
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="bottom"
				data-theme={GISCUS.theme}
				data-lang={GISCUS.lang}
				data-loading="lazy"
				crossorigin="anonymous"
				async
			/>
		) : (
			<p class="giscus-setup">
				评论尚未配置。请先在 GitHub 仓库开启 Discussions，再在 Vercel 添加{' '}
				<code>PUBLIC_GISCUS_REPO_ID</code> 与 <code>PUBLIC_GISCUS_CATEGORY_ID</code>。步骤见{' '}
				<code>ADMIN_SETUP.md</code>。
			</p>
		)
	}
</section>

<style>
	.giscus-wrapper {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.giscus-wrapper h2 {
		font-size: 1.25rem;
		margin-bottom: 1em;
	}
	.giscus-setup {
		color: rgb(var(--gray));
		font-size: 0.95em;
	}
	.giscus-setup code {
		background: rgb(var(--gray-light));
		padding: 0.1em 0.35em;
		border-radius: 4px;
	}
</style>
