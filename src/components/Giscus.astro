---
import { GISCUS } from '../consts';

const isConfigured = Boolean(GISCUS.repoId && GISCUS.categoryId);
---

<section class="giscus-wrapper" aria-labelledby="comments-title">
	<h2 id="comments-title">Discussion</h2>
	{
		isConfigured ? (
			<script
				is:inline
				src="https://giscus.app/client.js"
				data-repo={GISCUS.repo}
				data-repo-id={GISCUS.repoId}
				data-category={GISCUS.category}
				data-category-id={GISCUS.categoryId}
				data-mapping={GISCUS.mapping}
				data-term={GISCUS.term}
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="bottom"
				data-theme={GISCUS.theme}
				data-lang={GISCUS.lang}
				data-loading="lazy"
				crossorigin="anonymous"
				async
			/>
		) : (
			<p class="giscus-setup">
				Comments are ready in the site code. To enable GitHub login comments online,
				turn on GitHub Discussions for this repository, then add{' '}
				<code>PUBLIC_GISCUS_REPO_ID</code> and <code>PUBLIC_GISCUS_CATEGORY_ID</code> in
				Vercel. See <code>ADMIN_SETUP.md</code>.
			</p>
		)
	}
</section>

<style>
	.giscus-wrapper {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.giscus-wrapper h2 {
		font-size: 1.25rem;
		margin-bottom: 1em;
	}
	.giscus-setup {
		color: rgb(var(--gray));
		font-size: 0.95em;
	}
	.giscus-setup code {
		background: rgb(var(--gray-light));
		padding: 0.1em 0.35em;
		border-radius: 4px;
	}
</style>
