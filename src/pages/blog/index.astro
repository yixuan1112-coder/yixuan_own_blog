---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogNav from '../../components/BlogNav.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const grouped = posts.reduce<Record<string, typeof posts>>((acc, post) => {
	const year = post.data.pubDate.getFullYear().toString();
	(acc[year] ??= []).push(post);
	return acc;
}, {});
const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description="All blog posts." />
	</head>
	<body>
		<div class="site-frame">
			<Header />
			<main class="page-main">
				<div class="content-page">
					<BlogNav />
					<header class="page-heading">
						<h1 class="pixel-title page-title">Blog</h1>
						<p>{posts.length} posts</p>
					</header>

					{posts.length === 0 ? (
						<div class="empty-state">
							<p>No blog posts yet.</p>
						</div>
					) : (
						years.map((year) => (
							<section class="archive-year">
								<h2>{year}</h2>
								<ul>
									{grouped[year].map((post) => (
										<li>
											<a href={`/blog/${post.id}/`}>
												<span>
													<strong>{post.data.title}</strong>
													<small>{post.data.description}</small>
												</span>
												<time datetime={post.data.pubDate.toISOString()}><FormattedDate date={post.data.pubDate} /></time>
											</a>
										</li>
									))}
								</ul>
							</section>
						))
					)}
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
